{
  "name": "Character",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Character name"
    },
    "total_points": {
      "type": "number",
      "default": 10,
      "description": "Total skill points available"
    },
    "spent_points": {
      "type": "number",
      "default": 0,
      "description": "Points already spent"
    },
    "base_health": {
      "type": "number",
      "default": 10
    },
    "base_armor": {
      "type": "number",
      "default": 10
    },
    "base_speed": {
      "type": "number",
      "default": 15
    },
    "base_spell_range": {
      "type": "number",
      "default": 0
    },
    "crossbow_reload": {
      "type": "string",
      "enum": [
        "primary",
        "secondary",
        "tertiary"
      ],
      "default": "primary",
      "description": "Current reload action cost for crossbows"
    },
    "fire_damage": {
      "type": "string",
      "enum": [
        "none",
        "light",
        "medium",
        "heavy"
      ],
      "default": "none"
    },
    "frost_damage": {
      "type": "string",
      "enum": [
        "none",
        "light",
        "medium",
        "heavy"
      ],
      "default": "none"
    },
    "lightning_damage": {
      "type": "string",
      "enum": [
        "none",
        "light",
        "medium",
        "heavy"
      ],
      "default": "none"
    },
    "necrotic_damage": {
      "type": "string",
      "enum": [
        "none",
        "light",
        "medium",
        "heavy"
      ],
      "default": "none"
    },
    "used_single_use_skills": {
      "type": "array",
      "description": "Node IDs of single-use skills that have been used",
      "items": {
        "type": "string"
      }
    },
    "unlocked_skills": {
      "type": "array",
      "description": "Array of objects with tree_id and node_id",
      "items": {
        "type": "object",
        "properties": {
          "tree_id": {
            "type": "string"
          },
          "node_id": {
            "type": "string"
          }
        }
      }
    }
  },
  "required": [
    "name"
  ]
}